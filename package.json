{
  "name": "adga-suite",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3010",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "build:cf:ci": "opennextjs-cloudflare build",
    "deploy": "npm run build:cf && wrangler deploy",
    "preview": "npm run build:cf && wrangler dev",
    "cloudflare:production": "node scripts/cloudflare-production-setup.mjs",
    "verify:production": "node scripts/verify-production.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "lucide-react": "^0.575.0",
    "next": "^15.3.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "~5.8.2",
    "wrangler": "^4.93.0"
  }
}
